# AItem Scout — Edge Functions environment template.
# Copy to `.env` and fill values. Never commit the actual .env file.

# === Supabase (auto-injected when running `supabase functions serve`/`supabase functions deploy`,
# but listed here for reference and for cases where functions are invoked from a custom runtime) ===
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Public base URL of the frontend app. Used to construct absolute share URLs
# (`<SITE_URL>/share/<token>`) returned in ProjectDTO.share_url. If unset, share_url
# falls back to a relative path so the frontend can still join it with window.location.
SITE_URL=http://localhost:3000

# === LLM ===
# Anthropic Claude (Sonnet 4.6 default). Used by _shared/llm/claude.ts.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# === Search cache TTL (seconds). Default 24h. ===
SEARCH_CACHE_TTL_SECONDS=86400

# === Korea ===
# Naver Open API — https://developers.naver.com
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Kakao REST API (Daum blog + web search) — https://developers.kakao.com
KAKAO_REST_API_KEY=

# === Global ===
# YouTube Data API v3 — https://console.cloud.google.com
YOUTUBE_API_KEY=

# Google Trends has no official API; the connector uses an unofficial HTTP path
# and may benefit from a SerpAPI fallback. Leave blank to disable fallback.
SERPAPI_KEY=

# === Social ===
# Meta Graph API (Instagram Business + hashtag search). Long-lived user token.
META_ACCESS_TOKEN=
# Numeric IG Business account id used as `user-id` in hashtag-search queries.
META_IG_BUSINESS_ID=

# X (Twitter) API v2 bearer token — https://developer.x.com
X_BEARER_TOKEN=

# Threads Graph API — https://developers.facebook.com/docs/threads
THREADS_ACCESS_TOKEN=

# === Web search (optional fallbacks) ===
# Tavily web search — https://docs.tavily.com
TAVILY_API_KEY=
SERPER_API_KEY=
