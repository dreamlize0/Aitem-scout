# AItem Scout — Frontend (Next.js) 환경변수 템플릿
# 사용:
#   cp .env.example .env.local
# 값이 모두 비어 있으면 Mock 모드로 동작합니다 (검색은 src/lib/mockData.ts).
# Supabase URL/anon key를 채우면 실제 백엔드로 라우팅됩니다.

# ──────────────────────────────────────────────────────────────
# Supabase (선택, 없으면 Mock 모드)
# ──────────────────────────────────────────────────────────────
# Supabase 프로젝트 URL
NEXT_PUBLIC_SUPABASE_URL=
# Supabase anon (public) key. 서버에 안전하게 노출 가능한 키입니다.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ──────────────────────────────────────────────────────────────
# 사이트 (선택)
# ──────────────────────────────────────────────────────────────
# OAuth 리다이렉트와 공유 링크 절대 URL 빌드에 사용. 미설정 시
# window.location.origin으로 대체. 배포 시에는 반드시 채울 것.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
